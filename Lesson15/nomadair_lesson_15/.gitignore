# nomadair_lesson_15 — canonical ignore for this standalone Flutter app.
# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# Flutter/Dart/Pub
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
coverage/

app.*.symbols
app.*.map.json

# Android
/android/.gradle/
/android/app/debug/
/android/app/profile/
/android/app/release/
/android/local.properties
.cxx/

# Python / tooling (optional local artifacts)
__pycache__/
*.py[cod]
.pytest_cache/
venv/
.venv/
node_modules/

# Secrets — never commit
.env
.env.*
!.env.example

# Keystore (never commit real keys)
**/key.properties
**/*.keystore
**/*.jks
